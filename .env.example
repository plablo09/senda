# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://senda:senda@db/senda

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── Storage (MinIO locally, OpenStack Swift in production) ────────────────────
STORAGE_ENDPOINT=http://minio:9000
# Browser-reachable URL for rendered artifacts (nginx proxies /artefactos/ → MinIO in dev)
STORAGE_PUBLIC_ENDPOINT=http://localhost:9000
STORAGE_ACCESS_KEY=senda
STORAGE_SECRET_KEY=senda_dev
STORAGE_BUCKET=senda-documentos

# ── LLM (Gemini default — free tier sufficient for student guidance) ───────────
# Switch provider via env vars only — no code changes needed (LiteLLM abstraction).
#   Ollama (local):  LLM_MODEL=ollama/llama3.2  LLM_API_BASE=http://ollama:11434  LLM_API_KEY=
#                    Start with: docker compose --profile ollama up
#   Anthropic:       LLM_MODEL=anthropic/claude-haiku-4-5-20251001  LLM_API_KEY=sk-ant-...
#   OpenAI:          LLM_MODEL=gpt-4o-mini                          LLM_API_KEY=sk-...
#   Groq:            LLM_MODEL=groq/llama-3.1-8b-instant            LLM_API_KEY=gsk_...
LLM_MODEL=gemini/gemini-2.0-flash
LLM_API_BASE=
LLM_API_KEY=your-gemini-api-key-here

# ── LLM feedback rate limits ───────────────────────────────────────────────────
FEEDBACK_SILENCE_WINDOW=2
FEEDBACK_MAX_RESPONSES=3

# ── App ───────────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-in-production
EXECUTION_WS_URL=ws://localhost:8080/ws/ejecutar

# ── Execution containers ──────────────────────────────────────────────────────
EXEC_PYTHON_IMAGE=senda-exec-python
EXEC_R_IMAGE=senda-exec-r
EXEC_TIMEOUT_SECONDS=30
CONTAINER_POOL_SIZE_PYTHON=2
CONTAINER_POOL_SIZE_R=2
