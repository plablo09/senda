FROM r-base:4.4.2
RUN apt-get update && apt-get install -y --no-install-recommends \
    libgdal-dev libproj-dev libgeos-dev libudunits2-dev \
    && rm -rf /var/lib/apt/lists/*
RUN Rscript -e "install.packages(c('sf','terra','ggplot2','dplyr','tidyr','tmap','leaflet','spdep'), repos='https://cloud.r-project.org')"
WORKDIR /workspace
RUN useradd -m -u 1000 estudiante
USER estudiante
